{
  "name": "@cclrte/result",
  "version": "0.1.0",
  "description": "A small Result and Option toolkit for TypeScript.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CCLRTE/result.git"
  },
  "homepage": "https://github.com/CCLRTE/result#readme",
  "bugs": {
    "url": "https://github.com/CCLRTE/result/issues"
  },
  "keywords": [
    "typescript",
    "result",
    "option",
    "error-handling",
    "discriminated-union"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src/index.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun -e 'await (await import(\"node:fs/promises\")).rm(\"./dist\", { recursive: true, force: true })' && bun build ./src/index.ts --outdir ./dist --root ./src --target node --format esm --splitting --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:package": "bun run ./scripts/package-smoke.ts",
    "check": "bun run typecheck && bun run test && bun run build && bun run test:package",
    "prepack": "bun run check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
